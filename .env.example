# Local PostgreSQL. On Railway set DATABASE_URL to a reference variable such as
# ${{Postgres.DATABASE_URL}} on the web and worker services.
DATABASE_URL=postgresql://postgres@localhost:5432/ourvalleys
TEST_DATABASE_URL=postgresql://postgres@localhost:5432/ourvalleys_test

# A private random value of at least 32 characters. Never commit the real value.
BETTER_AUTH_SECRET=

# Local URLs. Railway deployments may omit these when RAILWAY_PUBLIC_DOMAIN is
# available; the application derives the canonical HTTPS origin safely.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
RAILWAY_PUBLIC_DOMAIN=

LOG_LEVEL=info
