{
  "name": "ourvalleys",
  "version": "0.1.0",
  "private": true,
  "description": "Local discovery and generated business website platform for Rhondda Cynon Taf.",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:seed": "node --conditions=react-server --import tsx scripts/seed.ts",
    "compatibility": "node --conditions=react-server --import tsx scripts/check-compatibility.ts",
    "worker": "tsx src/jobs/worker.ts"
  },
  "dependencies": {
    "better-auth": "1.6.23",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "pg-boss": "12.26.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
