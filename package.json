{
  "name": "ourvalleys",
  "version": "0.1.0",
  "private": true,
  "description": "Local discovery and generated business website platform for Rhondda Cynon Taf.",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "node scripts/generate-postcss-lock-fix.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm compatibility && pnpm test && pnpm build",
    "db:migrate": "node --conditions=react-server --import tsx scripts/migrate.ts",
    "db:seed": "node --conditions=react-server --import tsx scripts/seed.ts && node --conditions=react-server --import tsx scripts/seed-business-operations.ts",
    "auth:provision": "node --conditions=react-server --import tsx scripts/provision-account.ts",
    "auth:provision-admin": "node --conditions=react-server --import tsx scripts/provision-admin.ts",
    "auth:provision-demo": "node --conditions=react-server --import tsx scripts/provision-demo-account.ts",
    "deploy:validate": "node --conditions=react-server --import tsx scripts/validate-runtime.ts",
    "deploy:prepare": "pnpm deploy:validate && pnpm db:migrate && pnpm db:seed && pnpm auth:provision-demo",
    "compatibility": "node --conditions=react-server --import tsx scripts/check-compatibility.ts",
    "worker": "node --conditions=react-server --import tsx src/jobs/worker.ts",
    "worker:check": "node --conditions=react-server --import tsx scripts/check-worker.ts"
  },
  "dependencies": {
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "next": "16.2.11",
    "pg-boss": "12.26.1",
    "postgres": "3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
