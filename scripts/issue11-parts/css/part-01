 margin-top: 2rem;
  border-radius: 1rem;
  padding: 0.45rem;
  color: var(--ov-ink);
  background: #fff;
  box-shadow: 0 1.75rem 4.5rem rgba(0, 0, 0, 0.35);
}

.searchField {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: center;
  gap: 0.65rem;
  min-width: 0;
  border-radius: 0.7rem;
  padding: 0.45rem 0.7rem;
}

.searchField:first-child {
  border-right: 1px solid var(--ov-border-soft);
}

.searchIcon {
  display: grid;
  place-items: center;
  color: #7e8983;
}

.searchFieldText {
  display: grid;
  min-width: 0;
  gap: 0.08rem;
}

.searchFieldText label {
  font-size: 0.76rem;
  font-weight: 800;
}

.searchField input,
