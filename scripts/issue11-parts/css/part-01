  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
}

.businessCard,
.eventCard,
.guideCard {
  overflow: hidden;
  border: 1px solid var(--ov-border-soft);
  border-radius: var(--ov-radius-lg);
  background: #fff;
  transition:
    transform 230ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 230ms ease;
}

.businessCard:hover,
.eventCard:hover,
.guideCard:hover {
  box-shadow: var(--ov-shadow-md);
  transform: translateY(-0.3rem);
}

.businessCard a,
.guideCard a {
  color: inherit;
  text-decoration: none;
}

.cardMedia,
.eventMedia,
.guideMedia {
  position: relative;
  overflow: hidden;
  background: #dce5df;
}

.cardMedia {
  height: 10.6rem;
}

.cardMedia img,
.eventMedia img,
.guideMedia img,
.previewMedia img {
  object-fit: cover;
  transition: transform 500ms ease;
}

.businessCard:hover img,
.eventCard:hover img,
.guideCard:hover img {
