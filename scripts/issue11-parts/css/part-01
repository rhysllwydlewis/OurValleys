  width: 100%;
  min-width: 0;
  border: 0;
  padding: 0.12rem 0;
  color: var(--ov-ink);
  outline: 0;
  background: transparent;
  font-size: 0.91rem;
}

.searchField select {
  cursor: pointer;
}

.searchField:focus-within {
  box-shadow: inset 0 0 0 2px var(--ov-focus);
}

.searchSubmit {
  min-width: 7.1rem;
  border: 1px solid var(--ov-primary);
  border-radius: 0.7rem;
  padding: 0 1.45rem;
  color: #fff;
  background: var(--ov-primary);
  font-weight: 800;
  cursor: pointer;
}

.searchSubmit:hover {
  background: var(--ov-primary-strong);
}

.popularRow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-top: 1rem;
}

.popularRow > span {
  color: rgba(255, 255, 255, 0.74);
  font-size: 0.78rem;
  font-weight: 700;
}

.popularRow a {
  border: 1px solid rgba(255, 255, 255, 0.27);
  border-radius: var(--ov-radius-pill);
  padding: 0.37rem 0.76rem;
  color: #fff;
  background: rgba(255, 255, 255, 0.13);
  backdrop-filter: blur(0.5rem);
  font-size: 0.78rem;
  font-weight: 700;
  text-decoration: none;
}

.popularRow a:hover {
  background: rgba(255, 255, 255, 0.24);
}

.statsBand {
  position: relative;
  z-index: 3;
  border-bottom: 1px solid var(--ov-border-soft);
  background: #fff;
}

.statsGrid {
  display: grid;
  width: min(var(--ov-content), calc(100% - 2.5rem));
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin: 0 auto;
  padding: 1.45rem 0;
}

.stat {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.85rem;
  min-height: 3.4rem;
  border-right: 1px solid var(--ov-border-soft);
}

.stat:last-child {
  border-right: 0;
}

.statIcon {
  display: grid;
  width: 2.3rem;
  height: 2.3rem;
  place-items: center;
  border-radius: 0.75rem;
  color: var(--ov-primary);
  background: #eff5f0;
}

.stat strong {
  display: block;
  font-family: var(--ov-font-display);
  font-size: 1.25rem;
  font-weight: 600;
}

.stat span {
  color: var(--ov-ink-muted);
  font-size: 0.78rem;
}

.section {
  padding: clamp(3rem, 5vw, 4.75rem) 1.25rem 0;
}

.sectionInner {
  width: min(var(--ov-content), 100%);
  margin: 0 auto;
}

.sectionHeading {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 1.35rem;
}

